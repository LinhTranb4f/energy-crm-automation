# ClickUp API token (Personal token from https://app.clickup.com/settings/apps)
CLICKUP_API_TOKEN=your_clickup_api_token_here

# Full URL to the ClickUp document to download (e.g. doc.clickup.com or app.clickup.com)
DOWNLOAD_LINK=

# Optional: output directory (default: ./clickup_downloads)
# OUTPUT_DIR=./clickup_downloads
