{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "resolveJsonModule": true
  },
  "include": [
    "tests/**/*.ts",
    "client/**/*.ts",
    "actions/**/*.ts",
    "line-item/**/*.ts",
    "data/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}

